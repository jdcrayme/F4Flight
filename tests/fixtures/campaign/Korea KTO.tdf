#------------------
# Korean TDF file
#------------------

# shown in the pick list
name Korea KTO

# Title shown on theater page
desc Korean Theater of Operations - WARNING: Restart BMS after any theatre change.

# bitmap to display on theater page
bitmap Terrdata\theaterdefinition\Korea KTO.tga

# in general, you can miss out most of these, and it
# will use the default, unless another theater changes it
# so probably best to put in explicitly.
 
# Where the campaign directory is
campaigndir Campaign

# where the terrain data is
terraindir Terrdata\korea

# which tileset to use - overrides the global setting in the cfg file
# tileset POLAK

# where art is loaded from
artdir Art

# movies
moviedir 
 
# uisounds 
#uisounddir Sounds

# default objects
objectdir Terrdata\objects

# misc textures
misctexdir Terrdata\misctex

# 3d object files
3ddatadir Terrdata\objects

# sounds dir
sounddir Sounds

# simdata dir
simdatadir Sim

# minimum tacan channel
mintacan 1

# use double resolution 2D UI map
doubleres2dmap 1

# magnetic declination
magneticdeclination 0